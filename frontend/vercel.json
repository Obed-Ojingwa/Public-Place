{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "cleanUrls": true,
  "images": {
    "sizes": [16, 32, 48, 64, 96, 128, 256, 384],
    "domains": [
      "images.unsplash.com",
      "lottiefiles.com",
      "via.placeholder.com"
    ]
  }
}